{
  "name": "scribe",
  "version": "0.1.11",
  "description": "Local-first character database, build planner, and theorycrafting companion.",
  "author": "Elryck",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MyndGoblyn/SCRIBE.git"
  },
  "main": "./out/main/index.js",
  "private": true,
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "verify": "vitest run && tsc --noEmit && electron-vite build",
    "dist:win": "tsc --noEmit && electron-vite build && node scripts/import-nwnwiki.mjs && node scripts/build-win-installer.mjs --publish never",
    "release:win": "node scripts/release-win.mjs",
    "clean:workspace": "node scripts/clean-workspace.mjs",
    "import:nwnwiki": "node scripts/import-nwnwiki.mjs",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "electron-vite": "^4.0.0",
    "lucide-react": "^0.468.0",
    "sql.js": "^1.13.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "electron": "^37.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
